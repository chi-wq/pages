source "https://rubygems.org"
gem "jekyll", "~> 4.2"
gem "minima"               # 当前主题
gem "webrick"              # Windows 需要
gem "csv"                  # Ruby 3.4+ 不再内置 csv，Jekyll 依赖它
gem "base64"               # Ruby 3.4+ 不再内置 base64
gem "bigdecimal"           # Ruby 3.4+ 不再内置 bigdecimal
gem "liquid", ">= 4.0.4"  # 4.0.3 用到了 Ruby 3.2+ 已移除的 tainted?
gem "faraday-retry"        # Jekyll 4.x 需要
gem "jekyll-last-modified-at"  # 显示页面最后更新日期